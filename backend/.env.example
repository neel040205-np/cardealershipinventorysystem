# Server Environment Configuration
NODE_ENV=development
PORT=5000

# PostgreSQL Connection String (Supabase Connection Pool/Direct link)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cardealership?schema=public"

# Cryptographic Signatures for JWTs (Minimum 32 Characters)
JWT_ACCESS_SECRET="supersecretsignedkeywith32charactersforaccesstoken"
JWT_REFRESH_SECRET="supersecretsignedkeywith32charactersforrefreshtoken"

# CORS Authorization Origin URL
CORS_ORIGIN="http://localhost:3000"

# Winston Logger Verbosity Threshold (error, warn, info, debug)
LOG_LEVEL=debug
